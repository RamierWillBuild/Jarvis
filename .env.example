# ---------------------------------------------------------------------------
# Jarvis configuration. Copy to `.env` and edit. Every option is an env var.
# ---------------------------------------------------------------------------

# --- LLM provider ----------------------------------------------------------
# Which provider to use for summaries and chat: "openai" or "ollama".
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai). Leave blank to fall back to Ollama,
# and if neither is reachable Jarvis uses an offline extractive summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (used when LLM_PROVIDER=ollama, or as fallback). For Docker on
# Windows/macOS use http://host.docker.internal:11434 to reach the host.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional: reserved for a future NewsAPI source (not required for Phase 1).
NEWSAPI_KEY=

# --- News sources ----------------------------------------------------------
# Categories Jarvis tracks (also the togglable set on the Settings page).
NEWS_CATEGORIES=ai,technology,science,business,world

# Three configurable RSS feeds as comma-separated "category::url" pairs.
RSS_FEEDS=technology::https://techcrunch.com/feed/,science::http://feeds.arstechnica.com/arstechnica/index,world::http://feeds.bbci.co.uk/news/rss.xml

# How many top HackerNews stories to pull each run.
HN_STORY_LIMIT=20

# --- Pipeline / scheduler --------------------------------------------------
PIPELINE_INTERVAL_HOURS=6
RUN_PIPELINE_ON_STARTUP=true
SUMMARIZE_LIMIT=15
BRIEFING_ARTICLES_PER_CATEGORY=5

# --- Storage ---------------------------------------------------------------
DB_PATH=data/jarvis.db
SETTINGS_PATH=data/settings.json

# --- HTTP ------------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=15
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
